---
// src/pages/[lang]/blog.astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime.js';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'pt' } }
  ];
}

const { lang } = Astro.params;

const posts = await getCollection('blog', ({ data, id }) => {
  return data.draft !== true && id.startsWith(`${lang}/`);
});

// Sort all posts by publication date descending
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = Astro.site ? Astro.site.origin : 'https://britneyscripts.github.io';

// Extract all unique tags
const allTags = [
  ...new Set(
    posts.flatMap((post) => post.data.tags || [])
  )
].sort((a, b) => a.localeCompare(b));

const alternateUrls = [
  { lang: 'en', url: `${siteUrl}${baseUrl}/en/blog` },
  { lang: 'pt-BR', url: `${siteUrl}${baseUrl}/pt/blog` },
  { lang: 'x-default', url: `${siteUrl}${baseUrl}/en/blog` }
];
---

<Layout 
  title={`${lang === 'pt' ? 'Arquivo' : 'Blog Archive'} | Bê Acosta`} 
  description={lang === 'pt' ? "Artigos técnicos, notas de pesquisa e ensaios." : "All technical articles, research notes, and essays."}
  lang={lang === 'pt' ? 'pt-BR' : 'en'}
  alternateUrls={alternateUrls}
>
  <h1 style="font-family: var(--font-mono); margin-bottom: 2rem; border: none; padding: 0;">
    📄 archive_
  </h1>
  <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 3rem;">
    {lang === 'pt' 
      ? 'Uma coleção de notas, artigos técnicos e ensaios sobre como sistemas de IA interagem com arquiteturas web e e-commerce.' 
      : 'A collection of notes, technical write-ups, and structural essays on how AI systems interact with web and e-commerce architectures.'}
  </p>

  <div class="tags-container">
    <span class="tags-label">🏷️ tags:</span>
    <a href={`${baseUrl}/${lang}/blog`} class="tag-pill" data-tag="">all</a>
    {allTags.map((tag) => (
      <a href={`${baseUrl}/${lang}/blog?tag=${tag}`} class="tag-pill" data-tag={tag}>
        #{tag}
      </a>
    ))}
  </div>

  <div style="margin-bottom: 2rem;">
    <span style="color: var(--text-muted); font-size: 0.9rem; margin-right: 1rem;">🌐 Language:</span>
    <a href={`${baseUrl}/en/blog`} class="lang-link" style={lang === 'en' ? 'color: var(--accent-hover); font-weight: bold; border: none; margin-right: 0.5rem;' : 'border: none; margin-right: 0.5rem;'}>EN</a>
    <span style="color: var(--border);">|</span>
    <a href={`${baseUrl}/pt/blog`} class="lang-link" style={lang === 'pt' ? 'color: var(--accent-hover); font-weight: bold; border: none; margin-left: 0.5rem;' : 'border: none; margin-left: 0.5rem;'}>PT</a>
  </div>

  {sortedPosts.length > 0 ? (
    <div class="post-grid">
      {sortedPosts.map((post) => (
        <a href={`${baseUrl}/blog/${post.id}`} class="post-card post-item" data-tags={post.data.tags?.join(',') || ''}>
          <div class="post-card-meta">
            <span>
              {post.data.date.toLocaleDateString(lang === 'pt' ? 'pt-BR' : 'en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
            <span>•</span>
            <span>⏳ {getReadingTime(post.body)} {lang === 'pt' ? 'min de leitura' : 'min read'}</span>
          </div>
          <h2 class="post-card-title">{post.data.title}</h2>
          <p class="post-card-excerpt">{post.data.description}</p>
          {post.data.tags && (
            <div class="post-card-tags">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="post-card-tag">#{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <p style="color: var(--text-muted); font-style: italic;">
      {lang === 'pt' ? 'Nenhum artigo publicado ainda.' : 'No articles published yet.'} Stay tuned!
    </p>
  )}

  <script is:inline>
    function filterPostsByTag() {
      const urlParams = new URLSearchParams(window.location.search);
      const tag = urlParams.get('tag');
      
      const posts = document.querySelectorAll('.post-item');
      const tagPills = document.querySelectorAll('.tag-pill');
      
      // Update tag pills styling
      tagPills.forEach(pill => {
        const pillTag = pill.getAttribute('data-tag');
        if (pillTag === (tag || '')) {
          pill.classList.add('active');
        } else {
          pill.classList.remove('active');
        }
      });

      // Filter posts by tag
      posts.forEach(post => {
        const postTags = (post.getAttribute('data-tags') || '').split(',');
        const matchesTag = !tag || postTags.includes(tag);
        
        if (matchesTag) {
          post.style.display = 'block';
        } else {
          post.style.display = 'none';
        }
      });
    }

    // Run on load
    filterPostsByTag();

    // Intercept tag clicks to avoid reload and manage state
    document.querySelectorAll('.tag-pill').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetUrl = new URL(link.href);
        const targetParams = new URLSearchParams(targetUrl.search);
        
        // Update URL
        window.history.pushState({}, '', targetUrl.pathname + targetUrl.search);
        filterPostsByTag();
      });
    });

    window.addEventListener('popstate', filterPostsByTag);
  </script>
</Layout>
