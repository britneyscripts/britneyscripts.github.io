---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/readingTime.js';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const siteUrl = Astro.site ? Astro.site.origin : 'https://britneyscripts.github.io';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": `${siteUrl}/`,
      "name": "Bê Acosta",
      "description": "A technical blog and digital notebook on Agentic Commerce, RAG, embeddings, semantic search, and e-commerce infrastructure.",
      "publisher": {
        "@id": `${siteUrl}/#person`
      }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Bê Acosta",
      "alternateName": "Bettina Acosta de Paula",
      "url": `${siteUrl}/about`,
      "image": `${siteUrl}/images/profile.jpg`,
      "description": "Senior Technical Product Manager and researcher in Agentic Commerce, RAG, and e-commerce architectures.",
      "sameAs": [
        "https://twitter.com/britneyscripts",
        "https://substack.com/@evadepaula",
        "https://github.com/britneyscripts",
        "https://www.linkedin.com/in/bettina-acosta-de-paula/"
      ]
    }
  ]
};
---

<Layout title="Bê Acosta | AI, Data & E-commerce Infrastructure">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <div class="bio-card">
    <img src={`${baseUrl}/images/profile.jpg`} alt="Bê Acosta" class="bio-avatar" />
    <div class="hero-text">
      <h1 style="font-family: var(--font-mono); margin-bottom: 0.5rem; border: none; padding: 0; margin-top: 0; font-size: 1.8rem;">
        👋 hi, i'm b_ê acosta
      </h1>
      <p style="font-size: 1.15rem; color: var(--accent-hover); font-weight: 600; line-height: 1.4; margin-bottom: 0.5rem;">
        Senior PM | Product Discovery in E-commerce
      </p>
      <p style="font-size: 1rem; color: var(--text-muted); line-height: 1.5; margin: 0;">
        We're moving beyond traditional SEO into the era of <strong>Agentic Commerce</strong>. The digital shelf we built for human eyes is now being read by autonomous systems. I'm exploring this new world, and I'd love for you to join me.
      </p>
    </div>
  </div>

  <section class="intro" style="margin-bottom: 3.5rem;">
    <p>
      For almost a decade, I navigated SEO from all sides. My official title usually said "E-commerce Manager", but in reality, I was the Technical Product Manager desperately trying to explain why we couldn't just "add more keywords" to the front-end. Honestly, I always preferred the technical side anyway. So a while back, when I realized that AI agents were starting to read our product catalogs instead of humans, I fully pivoted to investigating LLMs and autonomous agents, especially Gemini, to understand exactly how they parse commerce.
    </p>
    <p>
      We're watching a massive shift not just in how search works, but in how we search. I bet you've already made at least 5 AI product searches this year (even if you just asked ChatGPT what to buy your mom for her birthday). When that happens, the engine does a ton of heavy lifting by running a RAG pipeline, checking embeddings, and querying databases to decide which brand gets a shiny recommendation and which one gets completely ghosted.
    </p>
    <p>
      If a store's data isn't structured for these machines to read, it essentially becomes invisible. That's exactly the problem I'm researching. I'm figuring out how Product Management needs to adapt to this new reality, and I'm sharing everything I learn right here.
    </p>
    
    <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.5rem; border-radius: 4px; margin: 2rem 0;">
      <h3 style="margin-top: 0; margin-bottom: 1rem; color: var(--text-primary); font-family: var(--font-mono);">
        🔍 What I study and track here:
      </h3>
      <p style="font-size: 0.98rem; margin-bottom: 1rem; color: var(--text-muted);">
        This space is where I document my research, tests, and audits on how AI engines discover and retrieve product data:
      </p>
      <ul style="list-style: square; margin-left: 1.5rem; font-size: 0.98rem; color: var(--text-primary);">
        <li style="margin-bottom: 0.75rem;">
          <strong>GEO (Generative Engine Optimization) & AEO (Answer Engine Optimization):</strong> How optimization shifts when we move from simple keywords to generative engines that synthesize answers on the fly.
        </li>
        <li style="margin-bottom: 0.75rem;">
          <strong>RAG Architecture & Knowledge Bases:</strong> The technical infrastructure needed to orchestrate inventory so LLMs can retrieve information in real-time without hallucinating stock or pricing.
        </li>
        <li style="margin-bottom: 0.75rem;">
          <strong>Vector Search & Embedding Models:</strong> The underlying logic that maps a buyer’s messy intent into multidimensional vectors.
        </li>
        <li style="margin-bottom: 0.75rem;">
          <strong>The Old Internet Vibe:</strong> Since this is my personal space, I'm also going to talk about cinema, music, and whatever else is on my mind, just to honor the good old days of the web.
        </li>
      </ul>
    </div>

    <p style="font-weight: 600; color: var(--text-primary);">
      This is where I document my attempts to figure out what happens when we stop optimizing for search bars and start building for autonomous agents.
      <a href={`${baseUrl}/about`} style="margin-left: 0.5rem;">Read my full story &rarr;</a>
    </p>
  </section>

  <section class="stack" style="margin-bottom: 3.5rem;">
    <h2>💻 My Stack</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[01] Data & AI</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          Python, SQL, dbt, BigQuery, PostgreSQL, SQLite, Google Gemini AI SDK, spaCy, ChromaDB.
        </p>
      </div>
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[02] Infrastructure</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          GCP (Cloud Run, Firebase), Docker, FastAPI, Git, GitHub Actions.
        </p>
      </div>
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[03] Commerce</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          Technical SEO, Schema.org structure, Adobe Commerce (Magento), VTEX, CrUX API.
        </p>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <h2>✍️ Latest Articles</h2>
    {latestPosts.length > 0 ? (
      <div class="post-grid">
        {latestPosts.map((post) => (
          <a href={`${baseUrl}/blog/${post.id}`} class="post-card">
            <div class="post-card-meta">
              <span>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              <span>•</span>
              <span>⏳ {getReadingTime(post.body)} min read</span>
            </div>
            <h3 class="post-card-title">{post.data.title}</h3>
            <p class="post-card-excerpt">{post.data.description}</p>
            {post.data.tags && (
              <div class="post-card-tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="post-card-tag">#{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p style="color: var(--text-muted); margin-top: 1.5rem; font-style: italic;">
        No articles published yet. The first one is coming tomorrow!
      </p>
    )}
    {posts.length > 3 && (
      <div style="margin-top: 2rem; font-family: var(--font-mono);">
        <a href={`${baseUrl}/blog`}>View the archive_</a>
      </div>
    )}
  </section>

  <section class="connect" style="margin-top: 4rem; border-top: 1px dashed var(--border); padding-top: 2rem;">
    <h2>🔗 Connect</h2>
    <p style="margin-top: 1rem; color: var(--text-muted);">
      Read my thoughts on Substack: <a href="https://substack.com/@evadepaula" target="_blank">@evadepaula</a><br />
      Find me on Twitter/X: <a href="https://twitter.com/britneyscripts" target="_blank">@britneyscripts</a><br />
      Let's align on LinkedIn: <a href="https://www.linkedin.com/in/bettina-acosta-de-paula/" target="_blank">Bettina Acosta de Paula</a>
    </p>
  </section>
</Layout>
