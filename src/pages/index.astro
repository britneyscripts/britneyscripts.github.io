---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

const siteUrl = Astro.site ? Astro.site.origin : 'https://britneyscripts.github.io';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": `${siteUrl}/`,
      "name": "Bê Acosta",
      "description": "A technical blog and digital notebook on Agentic Commerce, RAG, embeddings, semantic search, and e-commerce infrastructure.",
      "publisher": {
        "@id": `${siteUrl}/#person`
      }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Bê Acosta",
      "alternateName": "Bettina Acosta de Paula",
      "url": `${siteUrl}/about`,
      "image": `${siteUrl}/images/profile.jpg`,
      "description": "Senior Technical Product Manager and researcher in Agentic Commerce, RAG, and e-commerce architectures.",
      "sameAs": [
        "https://twitter.com/britneyscripts",
        "https://substack.com/@evadepaula"
      ]
    }
  ]
};
---

<Layout title="Bê Acosta | AI, Data & E-commerce Infrastructure">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <div class="hero-container">
    <div class="hero-text">
      <h1 style="font-family: var(--font-mono); margin-bottom: 1rem; border: none; padding: 0; margin-top: 0;">
        👋 hi, i'm b_ê acosta
      </h1>
      <p style="font-size: 1.35rem; color: var(--accent-hover); font-weight: 600; line-height: 1.4; margin-bottom: 1.5rem;">
        AI is reshaping how we discover and buy online. I'm exploring this new world, and I'd love for you to join me.
      </p>
      <p style="font-size: 1.15rem; color: var(--text-muted); line-height: 1.5; margin: 0;">
        We're moving beyond traditional SEO. The digital shelf we built for human eyes is now being read by autonomous systems. It's a fascinating shift into the era of <strong>Agentic Commerce</strong>, and I'm here to document the journey.
      </p>
    </div>
    <div class="profile-avatar-container">
      <img src={`${baseUrl}/images/profile.jpg`} alt="Bê Acosta" class="profile-avatar" />
    </div>
  </div>

  <section class="intro" style="margin-bottom: 3.5rem;">
    <p>
      Right now, AI engines like Gemini and ChatGPT are the ones doing the heavy lifting. When a user asks an LLM for a product recommendation, the algorithm runs a high-speed investigation. It processes RAG (Retrieval-Augmented Generation), crunches embeddings, and queries a database to decide which brand gets a live link and which one gets completely ignored.
    </p>
    <p>
      It might sound a bit intimidating at first, but it simply means that if our product data isn't easily understood by these new AI models, our stores might become invisible to them. My goal here is to figure out how we can adapt and prevent that from happening.
    </p>
    
    <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.5rem; border-radius: 4px; margin: 2rem 0;">
      <h3 style="margin-top: 0; margin-bottom: 1rem; color: var(--text-primary); font-family: var(--font-mono);">
        🔍 What I study and track here:
      </h3>
      <p style="font-size: 0.98rem; margin-bottom: 1rem; color: var(--text-muted);">
        This space is where I document my research, tests, and audits on how AI engines discover and retrieve product data:
      </p>
      <ul style="list-style: square; margin-left: 1.5rem; font-size: 0.98rem; color: var(--text-primary);">
        <li style="margin-bottom: 0.75rem;">
          <strong>GEO & AEO (Generative / Answer Engine Optimization):</strong> How optimization shifts when we move from simple keywords to generative engines that synthesize answers on the fly.
        </li>
        <li style="margin-bottom: 0.75rem;">
          <strong>RAG Architecture & Knowledge Bases:</strong> The technical infrastructure needed to orchestrate inventory so LLMs can retrieve information in real-time without hallucinating stock or pricing.
        </li>
        <li style="margin-bottom: 0.75rem;">
          <strong>Vector Search & Embedding Models:</strong> The underlying logic that maps a buyer’s messy intent into multidimensional vectors.
        </li>
      </ul>
    </div>

    <p style="font-weight: 600; color: var(--text-primary);">
      The goal isn't just to rank on a search bar anymore. It's making sure your data structure is ready for the agents.
      <a href={`${baseUrl}/about`} style="margin-left: 0.5rem;">Read my full story &rarr;</a>
    </p>
  </section>

  <section class="stack" style="margin-bottom: 3.5rem;">
    <h2>💻 My Stack</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 1.5rem;">
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[01] Data & AI</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          Python, SQL, dbt, BigQuery, PostgreSQL, SQLite, Google Gemini AI SDK, spaCy, ChromaDB.
        </p>
      </div>
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[02] Infrastructure</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          GCP (Cloud Run, Firebase), Docker, FastAPI, Git, GitHub Actions.
        </p>
      </div>
      <div style="background-color: var(--bg-secondary); border: 1px solid var(--border); padding: 1.25rem; border-radius: 4px;">
        <h3 style="font-family: var(--font-mono); color: var(--accent-hover); margin-bottom: 0.5rem; margin-top: 0;">[03] Commerce</h3>
        <p style="font-size: 0.95rem; margin: 0; color: var(--text-muted);">
          Technical SEO, Schema.org structure, Adobe Commerce (Magento), VTEX, CrUX API.
        </p>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <h2>✍️ Latest Articles</h2>
    {latestPosts.length > 0 ? (
      <ul class="post-list">
        {latestPosts.map((post) => (
          <li class="post-item">
            <div class="post-meta">
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
              <span style="margin-left: 0.75rem; font-weight: bold; color: var(--accent-hover);">{post.id.startsWith('pt/') ? '🇧🇷 PT' : '🇺🇸 EN'}</span>
            </div>
            <h3 class="post-title">
              <a href={`${baseUrl}/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="post-excerpt">{post.data.description}</p>
          </li>
        ))}
      </ul>
    ) : (
      <p style="color: var(--text-muted); margin-top: 1.5rem; font-style: italic;">
        No articles published yet. The first one is coming tomorrow!
      </p>
    )}
    {posts.length > 3 && (
      <div style="margin-top: 2rem; font-family: var(--font-mono);">
        <a href={`${baseUrl}/blog`}>View all articles_</a>
      </div>
    )}
  </section>

  <section class="connect" style="margin-top: 4rem; border-top: 1px dashed var(--border); padding-top: 2rem;">
    <h2>🔗 Connect</h2>
    <p style="margin-top: 1rem; color: var(--text-muted);">
      Read my thoughts on Substack: <a href="https://substack.com/@evadepaula" target="_blank">@evadepaula</a><br />
      Find me on Twitter/X: <a href="https://twitter.com/britneyscripts" target="_blank">@britneyscripts</a><br />
      Let's align on LinkedIn: <a href="https://www.linkedin.com/" target="_blank">Bettina Acosta de Paula</a>
    </p>
  </section>
</Layout>
