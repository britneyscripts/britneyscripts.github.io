---
// src/pages/blog.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort all posts by publication date descending
const sortedPosts = posts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

// Extract all unique tags
const allTags = [
  ...new Set(
    posts.flatMap((post) => post.data.tags || [])
  )
].sort((a, b) => a.localeCompare(b));
---

<Layout title="Blog Archive | Bê Acosta" description="All technical articles, research notes, and essays on Agentic Commerce and e-commerce pipelines.">
  <h1 style="font-family: var(--font-mono); margin-bottom: 2rem; border: none; padding: 0;">
    📄 archive_
  </h1>
  <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 3rem;">
    A collection of notes, technical write-ups, and structural essays on how AI systems interact with web and e-commerce architectures.
  </p>

  <div class="tags-container">
    <span class="tags-label">🏷️ tags:</span>
    <a href={`${baseUrl}/blog`} class="tag-pill" data-tag="">all</a>
    {allTags.map((tag) => (
      <a href={`${baseUrl}/blog?tag=${tag}`} class="tag-pill" data-tag={tag}>
        #{tag}
      </a>
    ))}
  </div>

  {sortedPosts.length > 0 ? (
    <ul class="post-list">
      {sortedPosts.map((post) => (
        <li class="post-item" data-lang={post.id.startsWith('pt/') ? 'pt' : 'en'} data-tags={post.data.tags?.join(',') || ''}>
          <div class="post-meta">
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
            <span style="margin-left: 0.75rem; font-weight: bold; color: var(--accent-hover);">{post.id.startsWith('pt/') ? '🇧🇷 PT' : '🇺🇸 EN'}</span>
          </div>
          <h2 class="post-title" style="border: none; padding: 0; margin: 0;">
            <a href={`${baseUrl}/blog/${post.id}`}>{post.data.title}</a>
          </h2>
          <p class="post-excerpt" style="margin-top: 0.5rem; margin-bottom: 0;">{post.data.description}</p>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--text-muted); font-style: italic;">
      No articles published yet. Stay tuned!
    </p>
  )}

  <script is:inline>
    function filterPosts() {
      const urlParams = new URLSearchParams(window.location.search);
      const lang = urlParams.get('lang');
      const tag = urlParams.get('tag');
      
      const posts = document.querySelectorAll('.post-item');
      const langLinks = document.querySelectorAll('.lang-link');
      const tagPills = document.querySelectorAll('.tag-pill');
      
      // Update language selectors styling
      langLinks.forEach(link => {
        const linkLang = new URL(link.href).searchParams.get('lang');
        if (linkLang === lang) {
          link.style.color = 'var(--accent-hover)';
          link.style.fontWeight = 'bold';
        } else {
          link.style.color = '';
          link.style.fontWeight = '';
        }
      });

      // Update tag pills styling
      tagPills.forEach(pill => {
        const pillTag = pill.getAttribute('data-tag');
        if (pillTag === (tag || '')) {
          pill.classList.add('active');
        } else {
          pill.classList.remove('active');
        }
      });

      // Filter posts by both lang and tag
      posts.forEach(post => {
        const postLang = post.getAttribute('data-lang');
        const postTags = (post.getAttribute('data-tags') || '').split(',');
        
        const matchesLang = !lang || postLang === lang;
        const matchesTag = !tag || postTags.includes(tag);
        
        if (matchesLang && matchesTag) {
          post.style.display = 'block';
        } else {
          post.style.display = 'none';
        }
      });
    }

    // Run on load
    filterPosts();

    // Intercept clicks to avoid reload on blog page and merge parameters
    document.querySelectorAll('.lang-link, .tag-pill').forEach(link => {
      link.addEventListener('click', (e) => {
        const path = window.location.pathname;
        if (path.endsWith('/blog') || path.endsWith('/blog/')) {
          e.preventDefault();
          const targetUrl = new URL(link.href);
          
          // Get current params and target params
          const currentParams = new URLSearchParams(window.location.search);
          const targetParams = new URLSearchParams(targetUrl.search);
          
          // Merge params
          if (link.classList.contains('lang-link')) {
            const newLang = targetParams.get('lang');
            if (newLang) {
              currentParams.set('lang', newLang);
            } else {
              currentParams.delete('lang');
            }
          } else if (link.classList.contains('tag-pill')) {
            const newTag = targetParams.get('tag');
            if (newTag) {
              currentParams.set('tag', newTag);
            } else {
              currentParams.delete('tag');
            }
          }
          
          // Update URL
          const newUrl = window.location.pathname + '?' + currentParams.toString();
          window.history.pushState({}, '', newUrl.replace(/\?$/, ''));
          filterPosts();
        }
      });
    });

    window.addEventListener('popstate', filterPosts);
  </script>
</Layout>
