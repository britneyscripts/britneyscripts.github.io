---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  lang?: string;
  alternateUrls?: { lang: string, url: string }[];
}

const { 
  title = "Bê Acosta | AI, Data & E-commerce Infrastructure", 
  description = "A technical blog and digital notebook on Agentic Commerce, RAG, embeddings, semantic search, and e-commerce infrastructure.",
  ogImage = "/images/blog_featured_image.png",
  ogType = "website",
  lang = "en",
  alternateUrls = []
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, ''); // Resolves base path dynamically, cleaning trailing slash

// Construct absolute URL for OG image (required by social crawlers)
const siteUrl = Astro.site ? Astro.site.origin : 'https://britneyscripts.github.io';
const cleanOgPath = ogImage.startsWith('/') ? ogImage : `/${ogImage}`;
const ogImageUrl = `${siteUrl}${cleanOgPath}`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      // Check for URL parameter to enable/disable tracking
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('internal_traffic') === 'true') {
        localStorage.setItem('exclude_analytics', 'true');
        alert('Analytics tracking disabled for this browser.');
      } else if (urlParams.get('internal_traffic') === 'false') {
        localStorage.removeItem('exclude_analytics');
        alert('Analytics tracking re-enabled.');
      }

      // Load GTM only if analytics are not excluded
      if (localStorage.getItem('exclude_analytics') !== 'true') {
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WX7B28BV');
      } else {
        console.log('🛑 Analytics disabled (Internal Traffic)');
      }
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg?v=3`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}/favicon-32x32.png?v=3`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}/favicon-16x16.png?v=3`} />
    <link rel="shortcut icon" href={`${baseUrl}/favicon.ico?v=3`} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Bê Acosta" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@britneyscripts" />
    <meta name="twitter:creator" content="@britneyscripts" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;700&family=Inter:wght@400;600;700&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- Hreflang Tags -->
    {alternateUrls.length > 0 && alternateUrls.map(({ lang, url }) => (
      <link rel="alternate" hreflang={lang} href={url} />
    ))}
    
    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WX7B28BV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div class="container">
      <header>
        <nav>
          <a href={baseUrl || '/'} class="logo" style="border: none;">
            <span style="font-family: var(--font-mono);"><span style="color: var(--accent-hover);">b</span>_</span>
          </a>
          <div class="nav-links">
            <a href={`${baseUrl}/`}>home</a>
            <a href={`${baseUrl}/blog`}>blog</a>
            <a href={`${baseUrl}/about`}>about</a>
            <span style="color: var(--border); margin-left: 1rem; margin-right: 0.5rem;">|</span>
            <a href={`${baseUrl}/en/blog`} class="lang-link" data-lang="en" style="margin-left: 0.25rem; border: none;">en</a>
            <a href={`${baseUrl}/pt/blog`} class="lang-link" data-lang="pt" style="margin-left: 0.5rem; border: none;">pt</a>
          </div>
        </nav>
      </header>
      
      <main>
        <slot /> <!-- This is where Astro injects page-specific content -->
      </main>

      <footer>
        <p>© {new Date().getFullYear()} Bê Acosta. Built with Astro & Obsidian. Checked by Antigravity.</p>
      </footer>
    </div>
  </body>
</html>
